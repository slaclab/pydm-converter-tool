endScreenProperties


# (Text Update, noedit, exponential format)
object activeXTextDspClass:noedit
beginObjectProperties
major 4
minor 6
release 0
x 10
y 10
w 120
h 18
controlPv "$(P):VAL"
format "exponential"
precision 3
showUnits
fgColor index 14
bgColor index 0
useDisplayBg
endObjectProperties

# (Text Update, noedit, decimal format)
object activeXTextDspClass:noedit
beginObjectProperties
major 4
minor 6
release 0
x 10
y 40
w 120
h 18
controlPv "$(P):RATE"
format "decimal"
endObjectProperties

# (Text Control, plain class - regression: still editable pv-text-input)
object activeXTextDspClass
