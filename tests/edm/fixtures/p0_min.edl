# (Static Text)
object activeXTextClass
beginObjectProperties
major 4
minor 1
release 1
x 10
y 20
w 120
h 18
font "helvetica-medium-r-12.0"
fgColor rgb 0 0 0
value {
  "Label $(PREFIX)"
}
endObjectProperties

# (Text Control)
object activeXTextDspClass
beginObjectProperties
major 4
minor 6
release 0
x 10
y 50
w 120
h 18
controlPv "$(PREFIX):SETPOINT"
precision 3
showUnits
endObjectProperties

# (Message Button)
object activeMessageButtonClass
beginObjectProperties
major 4
minor 0
release 0
x 10
y 80
w 80
h 24
buttonLabel "Go"
controlPv "$(PREFIX):GO"
pressValue "1"
endObjectProperties

