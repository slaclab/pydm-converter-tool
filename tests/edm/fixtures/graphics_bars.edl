# (Bar - pressure, vertical)
object activeBarClass
beginObjectProperties
major 4
minor 0
release 0
x 20
y 20
w 30
h 120
indicatorPv "$(P):PRESSURE"
min "0"
max "25"
orientation "vertical"
indicatorColor index 14
endObjectProperties

# (Slac Bar - flow, horizontal)
object activeSlacBarClass
