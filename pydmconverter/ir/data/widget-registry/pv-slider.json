{
  "id": "pv-slider",
  "version": "1.0.0",
  "displayName": "PV Slider",
  "description": "Slider control bound to a PV setpoint.",
  "category": "controls",
  "paletteIcon": "pv-slider.svg",

  "reactComponent": {
    "name": "PVSlider",
    "module": "@canopy/widgets"
  },

  "qtMapping": {
    "class": "PyDMSlider",
    "extends": "QSlider",
    "header": "pydm.widgets.slider"
  },

  "propSchema": {
    "$schema": "https://json-schema.org/draft-07/schema",
    "type": "object",
    "required": ["pv"],
    "properties": {
      "pv": { "type": "string", "format": "pv-channel" },
      "min": { "type": "number" },
      "max": { "type": "number" },
      "showValue": { "type": "boolean", "default": true },
      "orientation": {
        "type": "string",
        "enum": ["horizontal", "vertical"],
        "default": "horizontal"
      }
    }
  },

  "qtPropMap": {
    "channel": { "to": "pv", "transform": "stripProtocol" },
    "userMinimum": { "to": "min" },
    "userMaximum": { "to": "max" },
    "showValueLabel": { "to": "showValue" },
    "orientation": { "to": "orientation", "transform": "qtOrientation" }
  },

  "inspectorSchema": {
    "groups": [
      { "name": "PV", "fields": ["pv"] },
      { "name": "Range", "fields": ["min", "max"] },
      { "name": "Display", "fields": ["showValue", "orientation"] }
    ]
  },

  "defaults": { "width": 200, "height": 32 },

  "supportsPv": true,
  "supportsRules": true,
  "supportsChildren": false
}
