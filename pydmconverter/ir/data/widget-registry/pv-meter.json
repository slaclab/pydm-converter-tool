{
  "id": "pv-meter",
  "version": "1.0.0",
  "displayName": "PV Meter",
  "description": "Analog meter indicator for a numeric PV between configured limits.",
  "category": "indicators",
  "paletteIcon": "pv-meter.svg",

  "reactComponent": {
    "name": "PVMeter",
    "module": "@canopy/widgets"
  },

  "qtMapping": {
    "class": "PyDMAnalogIndicator",
    "extends": "QWidget",
    "header": "pydm.widgets.analog_indicator"
  },

  "propSchema": {
    "$schema": "https://json-schema.org/draft-07/schema",
    "type": "object",
    "required": ["pv"],
    "properties": {
      "pv": { "type": "string", "format": "pv-channel" },
      "min": { "type": "number", "default": 0 },
      "max": { "type": "number", "default": 100 },
      "label": { "type": "string" },
      "showValue": { "type": "boolean", "default": true },
      "units": { "type": "string" }
    }
  },

  "qtPropMap": {
    "channel": { "to": "pv", "transform": "stripProtocol" },
    "userMinimum": { "to": "min" },
    "userMaximum": { "to": "max" },
    "text": { "to": "label" },
    "showValueLabel": { "to": "showValue" },
    "units": { "to": "units" }
  },

  "inspectorSchema": {
    "groups": [
      { "name": "PV", "fields": ["pv"] },
      { "name": "Range", "fields": ["min", "max"] },
      { "name": "Display", "fields": ["label", "showValue", "units"] }
    ]
  },

  "defaults": { "width": 160, "height": 120 },

  "supportsPv": true,
  "supportsRules": true,
  "supportsChildren": false
}
