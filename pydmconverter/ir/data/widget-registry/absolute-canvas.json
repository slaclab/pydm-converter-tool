{
  "id": "absolute-canvas",
  "version": "1.0.0",
  "displayName": "Absolute Canvas",
  "description": "Root container for absolute-positioned screen widgets. One per screen.",
  "category": "containers",
  "paletteIcon": "absolute-canvas.svg",

  "reactComponent": {
    "name": "AbsoluteCanvas",
    "module": "@canopy/widgets"
  },

  "propSchema": {
    "$schema": "https://json-schema.org/draft-07/schema",
    "type": "object",
    "required": ["width", "height"],
    "properties": {
      "width": { "type": "integer", "minimum": 1 },
      "height": { "type": "integer", "minimum": 1 }
    }
  },

  "inspectorSchema": {
    "groups": [
      { "name": "Size", "fields": ["width", "height"] }
    ]
  },

  "defaults": { "width": 800, "height": 600 },

  "supportsPv": false,
  "supportsRules": false,
  "supportsChildren": true
}
