{
  "id": "tabs",
  "version": "1.0.0",
  "displayName": "Tabs",
  "description": "Multi-page container. Each tab is one named pane; children are assigned to tabs by index.",
  "category": "containers",
  "paletteIcon": "tabs.svg",

  "reactComponent": {
    "name": "Tabs",
    "module": "@canopy/widgets"
  },

  "qtMapping": {
    "class": "QTabWidget",
    "extends": "QWidget"
  },

  "propSchema": {
    "$schema": "https://json-schema.org/draft-07/schema",
    "type": "object",
    "required": ["tabs"],
    "properties": {
      "tabs": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "type": "string" }
          }
        }
      },
      "activeIndex": { "type": "integer", "minimum": 0, "default": 0 }
    }
  },

  "inspectorSchema": {
    "groups": [
      { "name": "Tabs", "fields": ["tabs", "activeIndex"] }
    ]
  },

  "defaults": { "width": 320, "height": 240 },

  "supportsPv": false,
  "supportsRules": true,
  "supportsChildren": true
}
