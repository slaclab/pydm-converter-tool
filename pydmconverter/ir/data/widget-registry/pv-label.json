{
  "id": "pv-label",
  "version": "1.0.0",
  "displayName": "PV Label",
  "description": "Displays a PV value as text with optional units, formatting, and alarm coloring.",
  "category": "indicators",
  "paletteIcon": "pv-label.svg",

  "reactComponent": {
    "name": "PVLabel",
    "module": "@canopy/widgets"
  },

  "qtMapping": {
    "class": "PyDMLabel",
    "extends": "QLabel",
    "header": "pydm.widgets.label"
  },

  "propSchema": {
    "$schema": "https://json-schema.org/draft-07/schema",
    "type": "object",
    "required": [],
    "properties": {
      "pv": {
        "type": "string",
        "title": "PV Channel",
        "description": "EPICS PV name (supports ${MACRO} substitution)",
        "format": "pv-channel"
      },
      "text": {
        "type": "string",
        "title": "Static Text",
        "description": "Static fallback text shown when no PV is bound (channel-less PyDMLabel)."
      },
      "precision": {
        "oneOf": [
          { "type": "number", "minimum": 0 },
          { "type": "string", "enum": ["fromPV"] }
        ],
        "default": "fromPV"
      },
      "showUnits": { "type": "boolean", "default": false },
      "alarmSensitive": { "type": "boolean", "default": false },
      "alarmBorder": { "type": "boolean", "default": false },
      "format": {
        "type": "string",
        "enum": ["default", "exponential", "hex", "binary", "string"],
        "default": "default"
      },
      "foregroundColor": { "type": "string" },
      "backgroundColor": { "type": "string" },
      "fontSize": {
        "type": "number",
        "title": "Font Size (px)"
      },
      "align": {
        "type": "string",
        "enum": ["left", "center", "right"],
        "default": "left"
      }
    }
  },

  "qtPropMap": {
    "channel": { "to": "pv", "transform": "stripProtocol" },
    "text": { "to": "text" },
    "precisionFromPV": { "to": "precision", "transform": "boolToFromPV" },
    "precision": { "to": "precision" },
    "showUnits": { "to": "showUnits" },
    "alarmSensitiveContent": { "to": "alarmSensitive" },
    "alarmSensitiveBorder": { "to": "alarmBorder" },
    "displayFormat": { "to": "format" },
    "foregroundColor": { "to": "foregroundColor" },
    "backgroundColor": { "to": "backgroundColor" },
    "fontSize": { "to": "fontSize" },
    "alignment": { "to": "align", "transform": "qtAlignment" }
  },

  "inspectorSchema": {
    "groups": [
      { "name": "PV", "fields": ["pv", "precision", "showUnits"] },
      { "name": "Display", "fields": ["format"] },
      { "name": "Alarm", "fields": ["alarmSensitive", "alarmBorder"] },
      { "name": "Appearance", "fields": ["foregroundColor", "backgroundColor"] }
    ]
  },

  "defaults": { "width": 100, "height": 24 },

  "supportsPv": true,
  "supportsRules": true,
  "supportsChildren": false
}
